# 242Go Environment Variables
# Copy this file to .env and fill in your values
# Add these same values as Environment Variables in Hostinger dashboard

# Anthropic API Key (for AI Kingdom Profile generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vite-prefixed versions (required for frontend access)
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Google Gemini (if switching to Gemini for AI profiles)
GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here
